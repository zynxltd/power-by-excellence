APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://powerbyexcellence.test
APP_BASE_DOMAIN=powerbyexcellence.test
APP_CENTRAL_HOSTS=powerbyexcellence.test,localhost,127.0.0.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.powerbyexcellence.test

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Prefer redis + Horizon. Falls back to database when Redis is down (QUEUE_REDIS_FALLBACK).
QUEUE_CONNECTION=redis
QUEUE_REDIS_FALLBACK=true
QUEUE_FALLBACK_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Mailtrap Email Sending (all app mail uses Laravel Mail / MessagingGateway smtp)
# API token: Mailtrap → Settings → API Tokens. Username is always "api".
# Sandbox (catch-only, no real delivery): host=sandbox.smtp.mailtrap.io, use inbox SMTP creds instead.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=api
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@portal.zynx.co.uk"
MAIL_FROM_NAME="${APP_NAME}"

# Messaging gateway email driver (smtp uses MAIL_* above; alternatives: sendgrid, mailgun, postmark, resend)
MESSAGING_EMAIL_PROVIDER=smtp

# Signup verification (set true to require email/phone/address steps after registration)
SIGNUP_EMAIL_VERIFICATION=false
SIGNUP_PHONE_VERIFICATION=
SIGNUP_ADDRESS_VERIFICATION=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

LIVE_STATS_INTERVAL=15

TELESCOPE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"

VALIDATION_DRIVER=demo
IPQS_API_KEY=
IPQS_FRAUD_SCORE_THRESHOLD=85
IPQS_STRICTNESS=1
